# Server
PORT=3000
NODE_ENV=development

# CORS (optional — defaults to allow all in dev)
CORS_ORIGIN=https://etienneagency.com

# SMTP email notifications (optional — form still saves to disk without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@etienneagency.com
NOTIFY_EMAIL=jim@etienneagency.com

# Airtable — source of truth for all form submissions
# Get your Personal Access Token at https://airtable.com/create/tokens
# Base ID and Table ID are in the Airtable URL: airtable.com/{BASE_ID}/{TABLE_ID}
AIRTABLE_PAT=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_ID=tbl...

# Analytics
# Vercel Analytics & Speed Insights are hardcoded via @vercel/analytics
# and @vercel/speed-insights packages — no env vars needed.
# They auto-detect Vercel deployments. For non-Vercel hosting, see:
# https://vercel.com/docs/analytics/quickstart
