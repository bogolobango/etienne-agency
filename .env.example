# Server
PORT=3000
NODE_ENV=development

# CORS (optional — defaults to allow all in dev)
CORS_ORIGIN=https://etienneagency.com

# SMTP email notifications (optional — form still saves to disk without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@etienneagency.com
NOTIFY_EMAIL=jim@etienneagency.com

# Analytics (Umami)
VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id
